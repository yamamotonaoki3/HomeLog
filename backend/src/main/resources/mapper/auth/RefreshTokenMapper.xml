<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.homelog.auth.mapper.RefreshTokenMapper">

    <resultMap id="refreshTokenResultMap" type="com.homelog.auth.entity.RefreshTokenEntity">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="tokenHash" column="token_hash"/>
        <result property="expiresAt" column="expires_at"/>
        <result property="revokedAt" column="revoked_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.homelog.auth.entity.RefreshTokenEntity"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO refresh_tokens (user_id, token_hash, expires_at)
        VALUES (#{userId}, #{tokenHash}, #{expiresAt})
    </insert>

    <select id="findByTokenHash" parameterType="string" resultMap="refreshTokenResultMap">
        SELECT id, user_id, token_hash, expires_at, revoked_at
        FROM refresh_tokens
        WHERE token_hash = #{tokenHash}
    </select>

    <update id="revokeByTokenHash">
        UPDATE refresh_tokens
        SET revoked_at = #{revokedAt}
        WHERE token_hash = #{tokenHash}
    </update>

</mapper>
