<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.homelog.auth.mapper.UserMapper">

    <resultMap id="userResultMap" type="com.homelog.auth.entity.UserEntity">
        <id property="id" column="id"/>
        <result property="email" column="email"/>
        <result property="passwordHash" column="password_hash"/>
        <result property="displayName" column="display_name"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.homelog.auth.entity.UserEntity" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO users (email, password_hash, display_name, created_at)
        VALUES (#{email}, #{passwordHash}, #{displayName}, #{createdAt})
    </insert>

    <select id="findByEmail" parameterType="string" resultMap="userResultMap">
        SELECT id, email, password_hash, display_name, created_at
        FROM users
        WHERE email = #{email}
    </select>

    <select id="findById" parameterType="long" resultMap="userResultMap">
        SELECT id, email, password_hash, display_name, created_at
        FROM users
        WHERE id = #{id}
    </select>

    <update id="updatePasswordHash">
        UPDATE users
        SET password_hash = #{passwordHash}
        WHERE id = #{id}
    </update>

</mapper>
